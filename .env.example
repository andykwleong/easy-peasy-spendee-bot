# Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs.
ME_TELEGRAM_IDS=
WIFE_TELEGRAM_IDS=

# Optional display labels written into Google Sheets.
ME_LABEL=Me
WIFE_LABEL=My wife

# Required only for scheduled Railway reminders and final summaries.
# Send /whoami in the group chat to see the Telegram chat ID.
TELEGRAM_CHAT_ID=

# Google Sheets
GOOGLE_SHEET_ID=

# Local Mac setup: use the path to your downloaded service account JSON file.
GOOGLE_SERVICE_ACCOUNT_FILE=

# Railway setup: paste the full service account JSON as one secret variable instead of using a local file path.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional sheet tab names.
RAW_EXPENSES_SHEET=Raw Expenses
FIXED_EXPENSES_SHEET=Fixed Expenses
MONTHLY_SUMMARY_SHEET=Monthly Summary
BOT_STATE_SHEET=Bot State

# Categories and payment setup
# Production setup: keep categories and payment setup in your Google Sheet tabs.
CATEGORIES_SHEET=Categories
CATEGORY_KEYWORDS_SHEET=Category Keywords
PAYMENT_METHODS_SHEET=Payment Methods
CARD_LIMITS_SHEET=Card Limits

# Optional. Enables screenshot, voice-note, natural-language delete/edit/question handling, and richer extraction.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
